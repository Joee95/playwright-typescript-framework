{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "types": ["node", "@playwright/test"],
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "tests/**/*.ts",
    "Pages/**/*.ts",
    "data/**/*.ts",
    "playwright.config.ts"
  ]
}